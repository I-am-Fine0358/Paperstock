{
    "name": "paperstock",
    "version": "1.0.1",
    "description": "PDF Bookshelf Manager for macOS — manage, organize, and read your PDF collection",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder --mac",
        "build:dmg": "electron-builder --mac dmg",
        "build:zip": "electron-builder --mac zip"
    },
    "build": {
        "appId": "com.paperstock.app",
        "productName": "Paperstock",
        "mac": {
            "target": [
                "dmg"
            ],
            "category": "public.app-category.productivity",
            "icon": "build/icon.icns"
        },
        "files": [
            "main.js",
            "preload.js",
            "lib/**/*",
            "src/**/*",
            "node_modules/**/*",
            "!node_modules/**/*.map",
            "!node_modules/**/*.md",
            "!node_modules/**/test/**",
            "!node_modules/**/docs/**"
        ],
        "directories": {
            "output": "dist"
        },
        "dmg": {
            "title": "Paperstock",
            "contents": [
                {
                    "x": 130,
                    "y": 220
                },
                {
                    "x": 410,
                    "y": 220,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        }
    },
    "keywords": [
        "pdf",
        "bookshelf",
        "reader",
        "macos",
        "electron"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@notionhq/client": "^5.16.0",
        "better-sqlite3": "^12.6.2",
        "pdfjs-dist": "^5.5.207"
    },
    "devDependencies": {
        "electron": "^40.6.1",
        "electron-builder": "^25.1.8"
    }
}
