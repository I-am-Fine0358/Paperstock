{
  "identifier": "default",
  "description": "Default capabilities for Paperstock",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask",
    "shell:allow-open",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:scope-app-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/**" }
      ]
    }
  ]
}
